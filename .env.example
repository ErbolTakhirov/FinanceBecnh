# FinanceBecnh — example environment file.
#
# Copy to `.env` and fill in the keys for the providers you want to use:
#     cp .env.example .env
#
# NEVER commit your real `.env`. It is gitignored by default.
# The `mock` provider and the `smoke` benchmark group need NONE of these —
# they run fully offline, deterministically, with no network access.
#
# Live (real-provider) runs are opt-in and require BOTH `--live` on the
# command AND:
FINANCEBENCH_LIVE=
# Set it to 1 to allow real network calls (and provide the relevant key below).

# --- OpenAI -----------------------------------------------------------------
OPENAI_API_KEY=

# --- Anthropic ----------------------------------------------------------------
ANTHROPIC_API_KEY=

# --- Google Gemini ------------------------------------------------------------
GEMINI_API_KEY=

# --- OpenRouter -----------------------------------------------------------
OPENROUTER_API_KEY=

# --- Generic OpenAI-compatible endpoint -----------------------------------
# Point this at any OpenAI-compatible server (vLLM, Ollama, llama.cpp
# `llama-server`, LM Studio, ...).
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=http://localhost:8000/v1

# --- Hugging Face (dataset downloads + optional Transformers/local inference) -
HF_TOKEN=

# --- Optional: LLM-judge model override (defaults to no judge configured) ----
FINANCEBENCH_JUDGE_MODEL=
